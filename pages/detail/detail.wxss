/* detail.wxss */

.page-container {
  background: #f5f6fa;
  min-height: 100vh;
  padding: 20rpx 24rpx;
}

/* ─── 加载/错误状态 ──────────────────────────────────────────────────────────── */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  color: #999;
  gap: 20rpx;
}

.error-icon { font-size: 80rpx; }
.error-text { font-size: 28rpx; }

/* ─── 头部卡片 ───────────────────────────────────────────────────────────────── */
.header-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.type-tag {
  padding: 8rpx 22rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.country-tag {
  padding: 8rpx 22rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  background: #f5f6fa;
  color: #555;
}

.source-tag {
  padding: 8rpx 22rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #888;
}

.case-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.title-en {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 24rpx;
  font-style: italic;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  min-width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.keywords-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.keyword-tag {
  padding: 8rpx 22rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #EBF3FC;
  color: #1A6FBF;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-stats {
  display: flex;
  gap: 20rpx;
}

.stat {
  font-size: 24rpx;
  color: #999;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.source-btn, .fav-btn {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  border: 2rpx solid #e0e0e0;
  color: #666;
}

.fav-btn.favorited {
  background: #FEF9E7;
  border-color: #F39C12;
  color: #F39C12;
}

/* ─── 评分卡片 ───────────────────────────────────────────────────────────────── */
.score-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.score-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.score-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.score-badge-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  font-weight: 500;
}

.score-bar-wrap {
  margin-bottom: 16rpx;
}

.score-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.score-reason {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.score-dims {
  display: flex;
  gap: 0;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 20rpx;
}

.dim-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-right: 1rpx solid #f5f5f5;
}

.dim-item:last-child {
  border-right: none;
}

.dim-label {
  font-size: 22rpx;
  color: #999;
}

.dim-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A6FBF;
}

/* ─── 摘要卡片 ───────────────────────────────────────────────────────────────── */
.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.summary-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.summary-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: #1A6FBF;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.summary-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

/* ─── 内容卡片 ───────────────────────────────────────────────────────────────── */
.content-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.tab-bar {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #1A6FBF;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1A6FBF;
  border-radius: 2rpx;
}

.content-body {
  padding: 28rpx 32rpx;
  max-height: 1000rpx;
  overflow-y: auto;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.no-content {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}
