/* ─── 页面容器 ─────────────────────────────────────────────────────────────── */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f4f8;
  box-sizing: border-box;
}

/* ─── 顶部工具栏 ─────────────────────────────────────────────────────────────── */
.chat-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eef0f3;
  flex-shrink: 0;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.toolbar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2d47;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2ecc71;
  margin-left: 8rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-text {
  font-size: 22rpx;
  color: #2ecc71;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  background: #f5f6fa;
}

.clear-icon {
  font-size: 26rpx;
}

.clear-text {
  font-size: 24rpx;
  color: #888;
}

/* ─── 未登录提示页 ──────────────────────────────────────────────────────────── */
.login-gate {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
}

.gate-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.gate-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2d47;
  margin-bottom: 16rpx;
}

.gate-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.gate-features {
  width: 100%;
  margin-bottom: 56rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #f5f8ff;
  border-radius: 12rpx;
  border: 1rpx solid #dce8f8;
}

.feature-icon {
  font-size: 36rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #444;
}

.gate-login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1A6FBF, #2980b9);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(26, 111, 191, 0.35);
}

.gate-login-btn:active {
  opacity: 0.85;
}

.offline {
  background: #ccc !important;
  animation: none !important;
}

.offline-text {
  color: #999 !important;
}

/* ─── 消息滚动区 ─────────────────────────────────────────────────────────────── */
.msg-scroll {
  flex: 1;
  /* min-height: 0 是 flex 子项内 scroll-view 能正确伸缩的关键 */
  min-height: 0;
  overflow: hidden;
}

.msg-list {
  padding: 24rpx 24rpx 0;
}

/* ─── 消息行 ─────────────────────────────────────────────────────────────────── */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 32rpx;
}

.ai-row {
  flex-direction: row;
}

.user-row {
  flex-direction: row-reverse;
}

/* ─── 头像 ───────────────────────────────────────────────────────────────────── */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #1A6FBF, #2980b9);
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(26, 111, 191, 0.3);
}

.user-avatar {
  background: linear-gradient(135deg, #e8f0fe, #c5d8f8);
  margin-left: 16rpx;
}

.avatar-emoji {
  font-size: 36rpx;
}

/* ─── 气泡 ───────────────────────────────────────────────────────────────────── */
.bubble-wrap {
  max-width: 66%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.bubble-wrap-user {
  align-items: flex-end;
}

.bubble {
  padding: 22rpx 28rpx;
  border-radius: 20rpx;
  word-break: break-all;
}

.ai-bubble {
  background: #ffffff;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  background: linear-gradient(135deg, #1A6FBF, #2980b9);
  border-bottom-right-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 111, 191, 0.25);
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

.ai-bubble .bubble-text {
  color: #2c3e50;
}

.user-bubble .bubble-text {
  color: #ffffff;
}

.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* ─── 思考中动画 ─────────────────────────────────────────────────────────────── */
.dot-wave {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 0;
  min-width: 60rpx;
  min-height: 36rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #c0cfe0;
  animation: dotBounce 1.4s infinite ease-in-out;
}

.d1 { animation-delay: 0s; }
.d2 { animation-delay: 0.2s; }
.d3 { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(1);
    background: #c0cfe0;
  }
  40% {
    transform: scale(1.5);
    background: #1A6FBF;
  }
}

/* ─── 快捷问题 ───────────────────────────────────────────────────────────────── */
.quick-section {
  margin: 8rpx 0 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.quick-title {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 20rpx;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f5f8ff;
  border-radius: 12rpx;
  border: 1rpx solid #dce8f8;
  transition: background 0.2s;
}

.quick-item:active {
  background: #e0ecff;
}

.quick-text {
  font-size: 26rpx;
  color: #1a6fbf;
  flex: 1;
  line-height: 1.4;
}

.quick-arrow {
  font-size: 32rpx;
  color: #1a6fbf;
  margin-left: 10rpx;
  font-weight: 300;
}

/* ─── 底部输入区 ─────────────────────────────────────────────────────────────── */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef0f3;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  gap: 16rpx;
}

.input-wrap {
  flex: 1;
  background: #f5f6fa;
  border-radius: 44rpx;
  border: 1rpx solid #e8eaf0;
}

.chat-input {
  width: 100%;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  max-height: 120rpx;
}

.chat-placeholder {
  color: #bbb;
}

.send-btn {
  width: 100rpx;
  height: 76rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 500;
  transition: opacity 0.2s;
}

.send-active {
  background: linear-gradient(135deg, #1A6FBF, #2980b9);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(26, 111, 191, 0.35);
}

.send-disabled {
  background: #e8eaf0;
  color: #aaa;
}

/* 发送按钮加载动画 */
.send-loading {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.mini-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fff;
  animation: dotBounce 1.4s infinite ease-in-out;
}

.mini-dot:nth-child(2) { animation-delay: 0.2s; }
.mini-dot:nth-child(3) { animation-delay: 0.4s; }
