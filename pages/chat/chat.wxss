/* ════════════════════════════════════════════════════
   页面根容器
════════════════════════════════════════════════════ */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f2f5f9;
  overflow: hidden;
  box-sizing: border-box;
}

/* ════════════════════════════════════════════════════
   顶部导航栏
════════════════════════════════════════════════════ */
.navbar {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #edf0f5;
  flex-shrink: 0;
  position: relative;
}

.navbar-left {
  width: 100rpx;
  display: flex;
  align-items: center;
}

.history-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  background: #f2f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-icon {
  font-size: 34rpx;
  color: #555;
  line-height: 1;
}

.navbar-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.navbar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2d47;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.navbar-right {
  width: 140rpx;
  display: flex;
  justify-content: flex-end;
}

.new-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #1A6FBF;
  border-radius: 30rpx;
}

.new-icon {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

.new-text {
  font-size: 24rpx;
  color: #fff;
}

.new-btn:active {
  opacity: 0.8;
}

.login-btn-small {
  padding: 12rpx 24rpx;
  background: #1A6FBF;
  border-radius: 30rpx;
}

.login-btn-text {
  font-size: 26rpx;
  color: #fff;
}

/* ════════════════════════════════════════════════════
   未登录引导页
════════════════════════════════════════════════════ */
.gate {
  flex: 1;
  overflow-y: auto;
  padding: 40rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.gate-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.gate-logo {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.gate-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2d47;
  margin-bottom: 10rpx;
}

.gate-slogan {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.gate-divider {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #1A6FBF, #5ba3e0);
  border-radius: 2rpx;
  margin-bottom: 32rpx;
}

.gate-feature-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.gate-feature {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.gf-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1A6FBF;
  flex-shrink: 0;
}

.gf-text {
  font-size: 26rpx;
  color: #555;
}

.gate-login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(26, 111, 191, 0.3);
}

.gate-login-btn:active { opacity: 0.85; }

.gate-examples {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.examples-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.example-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.example-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
  border: 1rpx solid #e8edf5;
}

.example-text {
  font-size: 26rpx;
  color: #888;
  flex: 1;
  line-height: 1.4;
}

.example-lock {
  font-size: 24rpx;
  margin-left: 12rpx;
  opacity: 0.5;
}

/* ════════════════════════════════════════════════════
   消息滚动区
════════════════════════════════════════════════════ */
.msg-scroll {
  flex: 1;
  min-height: 0;
}

.msg-list {
  padding: 20rpx 20rpx 0;
}

/* ════════════════════════════════════════════════════
   消息行 & 气泡
════════════════════════════════════════════════════ */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 28rpx;
  gap: 14rpx;
}

.row-ai  { flex-direction: row; }
.row-user { flex-direction: row-reverse; }

/* 头像 */
.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  box-shadow: 0 4rpx 12rpx rgba(26,111,191,0.25);
}

.avatar-user {
  background: linear-gradient(135deg, #dce8f8, #c0d8f0);
}

.avatar-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-user .avatar-text {
  color: #1A6FBF;
}

/* 气泡列 */
.bubble-col {
  max-width: 68%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.bubble-col-user {
  align-items: flex-end;
}

/* 气泡本体 */
.bubble {
  padding: 20rpx 26rpx;
  border-radius: 18rpx;
  word-break: break-all;
}

.bubble-ai {
  background: #fff;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.bubble-user {
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  border-bottom-right-radius: 4rpx;
  box-shadow: 0 4rpx 14rpx rgba(26,111,191,0.22);
}

.bubble-txt {
  font-size: 28rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.bubble-ai  .bubble-txt { color: #2c3e50; }
.bubble-user .bubble-txt { color: #fff; }

/* ── AI 消息 rich-text 容器 ── */
.ai-rich {
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.8;
  display: block;
  /* rich-text 默认 inline，需设为 block 才能撑开宽度 */
  word-break: break-all;
}

.msg-time {
  font-size: 20rpx;
  color: #c0c8d8;
  margin-top: 6rpx;
}

/* ════════════════════════════════════════════════════
   思考动画
════════════════════════════════════════════════════ */
.thinking {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 32rpx;
  min-width: 56rpx;
}

.t-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #b0c4de;
  animation: tBounce 1.3s infinite ease-in-out;
}

.td1 { animation-delay: 0s; }
.td2 { animation-delay: 0.2s; }
.td3 { animation-delay: 0.4s; }

@keyframes tBounce {
  0%, 70%, 100% { transform: scale(1); background: #b0c4de; }
  35% { transform: scale(1.6); background: #1A6FBF; }
}

/* ════════════════════════════════════════════════════
   快捷问题卡片
════════════════════════════════════════════════════ */
.quick-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.quick-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.quick-icon { font-size: 28rpx; }
.quick-label { font-size: 24rpx; color: #999; }

.quick-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quick-chip {
  padding: 18rpx 20rpx;
  background: #f4f8ff;
  border-radius: 12rpx;
  border: 1rpx solid #dce9f8;
}

.quick-chip:active { background: #dce9f8; }

.chip-txt {
  font-size: 26rpx;
  color: #1A6FBF;
  line-height: 1.45;
}

/* ════════════════════════════════════════════════════
   底部输入区
════════════════════════════════════════════════════ */
.input-area {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  padding: 14rpx 20rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #edf0f5;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  background: #f2f5f9;
  border-radius: 20rpx;
  border: 1rpx solid #e4e8f0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.input-field {
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #2c3e50;
  min-height: 68rpx;
  max-height: 160rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

.input-ph { color: #bbb; }

.char-count {
  font-size: 20rpx;
  color: #f39c12;
  padding: 0 20rpx 8rpx;
  text-align: right;
}

.send-btn {
  width: 100rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-on {
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  box-shadow: 0 4rpx 14rpx rgba(26,111,191,0.3);
}

.send-off {
  background: #dde3ed;
}

.send-txt {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.send-off .send-txt { color: #aaa; }

.send-loading {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.sl-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fff;
  animation: tBounce 1.3s infinite ease-in-out;
}

.sl-dot:nth-child(2) { animation-delay: 0.2s; }
.sl-dot:nth-child(3) { animation-delay: 0.4s; }

/* ════════════════════════════════════════════════════
   历史会话侧边栏
════════════════════════════════════════════════════ */
.history-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

.history-panel {
  position: fixed;
  top: 0; left: 0;
  width: 76vw;
  max-width: 560rpx;
  height: 100vh;
  background: #fff;
  z-index: 101;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 8rpx 0 32rpx rgba(0,0,0,0.12);
}

.panel-open {
  transform: translateX(0);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f2f6;
  flex-shrink: 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2d47;
}

.panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f2f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

/* 历史列表 */
.history-scroll {
  flex: 1;
  min-height: 0;
  padding: 8rpx 0;
}

.h-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f7fa;
  transition: background 0.15s;
}

.h-item:active { background: #f5f8ff; }

.h-item-active {
  background: #eef4ff;
  border-left: 4rpx solid #1A6FBF;
}

.h-item-body {
  flex: 1;
  overflow: hidden;
}

.h-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2c3e50;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.h-item-meta {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.h-item-count, .h-item-sep, .h-item-time {
  font-size: 22rpx;
  color: #aab;
}

.h-item-preview {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.h-del-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.h-del-btn:active { background: #fff0f0; }

.h-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
}

.h-nomore {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  padding: 20rpx;
}

/* 空状态 */
.panel-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-tip { font-size: 26rpx; color: #bbb; }

/* 面板底部新建按钮 */
.panel-new-btn {
  flex-shrink: 0;
  margin: 16rpx 24rpx;
  margin-bottom: calc(16rpx + env(safe-area-inset-bottom));
  height: 84rpx;
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(26,111,191,0.25);
}

.panel-new-btn:active { opacity: 0.85; }

/* ════════════════════════════════════════════════════
   骨架屏
════════════════════════════════════════════════════ */
.sk-item {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f7fa;
}

.sk-line {
  background: linear-gradient(90deg, #f0f2f6 25%, #e4e8f0 50%, #f0f2f6 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: skeleton 1.4s infinite;
}

.sk-title { height: 28rpx; width: 70%; margin-bottom: 12rpx; }
.sk-sub   { height: 22rpx; width: 45%; }

@keyframes skeleton {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
