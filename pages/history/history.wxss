/* history.wxss */
.page-container {
  background: #f5f6fa;
  min-height: 100vh;
  padding: 0 24rpx 20rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx;
}

.total-text { font-size: 24rpx; color: #999; }

.edit-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.edit-btn {
  font-size: 28rpx;
  color: #1A6FBF;
  padding: 8rpx 20rpx;
}

.delete-btn {
  font-size: 26rpx;
  color: #ccc;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
}

.delete-btn.active {
  color: #E74C3C;
  background: #FDEDEC;
}

.record-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  gap: 16rpx;
}

.record-card:active { opacity: 0.85; }

.checkbox {
  flex-shrink: 0;
  padding-top: 4rpx;
}

.check-icon {
  font-size: 44rpx;
  color: #1A6FBF;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-header {
  margin-bottom: 10rpx;
}

.time-str {
  font-size: 22rpx;
  color: #bbb;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
  margin-bottom: 6rpx;
}

.record-title-en {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  font-style: italic;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 16rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; color: #666; font-weight: 500; }
.empty-sub { font-size: 26rpx; color: #999; }
