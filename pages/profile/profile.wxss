/* profile.wxss */

.page-container {
  background: #f5f6fa;
  min-height: 100vh;
}

/* ─── 用户头部 ───────────────────────────────────────────────────────────────── */
.user-header {
  background: linear-gradient(135deg, #1A6FBF, #145A9E);
  padding: 40rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.2);
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-role {
  font-size: 22rpx;
  color: #F39C12;
  background: rgba(243,156,18,0.2);
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  align-self: flex-start;
}

.user-role.normal {
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.15);
}

.user-stats {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* ─── 未登录状态 ─────────────────────────────────────────────────────────────── */
.not-login {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.login-prompt {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.login-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.arrow-right {
  font-size: 48rpx;
  color: rgba(255,255,255,0.5);
}

/* ─── 功能菜单 ───────────────────────────────────────────────────────────────── */
.menu-section {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: -20rpx;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  gap: 20rpx;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-wrap.fav { background: #FEF9E7; }
.menu-icon-wrap.notes { background: #eef6ff; }
.menu-icon-wrap.feedback { background: #e8f4ff; }
.menu-icon-wrap.history { background: #EBF3FC; }
.menu-icon-wrap.about { background: #EAFAF1; }

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
  background: #f5f6fa;
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.menu-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 30rpx;
}

.menu-item.logout {
  justify-content: center;
}

.logout-text {
  font-size: 30rpx;
  color: #E74C3C;
}

/* ─── 版本信息 ───────────────────────────────────────────────────────────────── */
.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #ccc;
}
