/* login.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A6FBF 0%, #f5f6fa 45%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 60rpx;
}

/* ─── 顶部英雄区 ─────────────────────────────────────────────────────────────── */
.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
  gap: 16rpx;
}

.hero-icon {
  font-size: 100rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.2));
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
}

/* ─── 登录卡片 ───────────────────────────────────────────────────────────────── */
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.card-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

/* ─── 头像 ───────────────────────────────────────────────────────────────────── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  padding: 0;
  background: transparent;
  border: none;
  overflow: visible;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid #e0e0e0;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  background: #1A6FBF;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 4rpx solid #fff;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
}

/* ─── 昵称输入 ───────────────────────────────────────────────────────────────── */
.nickname-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333;
  text-align: center;
}

/* ─── 登录按钮 ───────────────────────────────────────────────────────────────── */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1A6FBF, #145A9E);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: none;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.loading {
  opacity: 0.7;
}

.skip-btn {
  padding: 16rpx 40rpx;
}

.skip-btn text {
  font-size: 28rpx;
  color: #999;
}

/* ─── 隐私说明 ───────────────────────────────────────────────────────────────── */
.privacy-note {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #bbb;
  display: flex;
  gap: 4rpx;
}

.link {
  color: #1A6FBF;
}
