<view class="page">
  <view class="tip-card">
    <text class="tip-text">请描述您遇到的问题或建议，我们会尽快查看。</text>
  </view>

  <view class="form-card">
    <view class="label">反馈内容 <text class="req">*</text></view>
    <textarea
      class="textarea"
      placeholder="请详细描述问题或建议，便于我们改进（必填）"
      placeholder-class="ph"
      maxlength="2000"
      value="{{content}}"
      bindinput="onContentInput"
      show-confirm-bar="{{false}}"
    />
    <view class="counter">{{contentLen}}/2000</view>

    <view class="label mt">联系方式（选填）</view>
    <input
      class="input"
      placeholder="手机号 / 微信号，便于回访"
      maxlength="100"
      value="{{contact}}"
      bindinput="onContactInput"
    />
  </view>

  <view
    class="submit-btn {{submitting ? 'disabled' : ''}}"
    bindtap="onSubmit"
  >
    {{submitting ? '提交中…' : '提交反馈'}}
  </view>
</view>
