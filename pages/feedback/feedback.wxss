.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f6fa;
  box-sizing: border-box;
}

.tip-card {
  background: #ebf3fc;
  border: 1rpx solid #d0ddf0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.label.mt {
  margin-top: 28rpx;
}

.req {
  color: #e74c3c;
}

.textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #333;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.ph {
  color: #bbb;
}

.counter {
  font-size: 22rpx;
  color: #aaa;
  text-align: right;
  margin-top: 8rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #1A6FBF, #3a90d4);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 111, 191, 0.35);
}

.submit-btn.disabled {
  opacity: 0.55;
}
