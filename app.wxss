/* app.wxss - 全局样式 */

/* ─── CSS 变量 ─────────────────────────────────────────────────────────────── */
page {
  --primary: #1A6FBF;
  --primary-light: #EBF3FC;
  --primary-dark: #145A9E;
  --accent: #F39C12;
  --success: #27AE60;
  --danger: #E74C3C;
  --warning: #F39C12;
  --text-primary: #1a1a2e;
  --text-secondary: #666;
  --text-muted: #999;
  --border: #e8e8e8;
  --bg: #f5f6fa;
  --bg-card: #ffffff;
  --radius: 12rpx;
  --radius-lg: 20rpx;
  --shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  --shadow-md: 0 4rpx 20rpx rgba(0,0,0,0.12);

  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ─── 重置 ──────────────────────────────────────────────────────────────────── */
view, text, image, input, button, scroll-view {
  box-sizing: border-box;
}

/* ─── 通用卡片 ──────────────────────────────────────────────────────────────── */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* ─── 按钮 ──────────────────────────────────────────────────────────────────── */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 40rpx;
  height: 80rpx;
  border: none;
  outline: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-ghost {
  background: var(--primary-light);
  color: var(--primary);
}

.btn-sm {
  height: 60rpx;
  font-size: 24rpx;
  padding: 0 28rpx;
}

/* ─── 标签 ──────────────────────────────────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.tag-civil { background: #EBF3FC; color: #1A6FBF; }
.tag-criminal { background: #FDEDEC; color: #E74C3C; }
.tag-admin { background: #FEF9E7; color: #F39C12; }
.tag-commercial { background: #EAFAF1; color: #27AE60; }
.tag-default { background: #f0f0f0; color: #666; }

/* ─── 分割线 ─────────────────────────────────────────────────────────────────── */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* ─── 空状态 ─────────────────────────────────────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-muted);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* ─── 加载更多 ───────────────────────────────────────────────────────────────── */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

/* ─── 文字省略 ───────────────────────────────────────────────────────────────── */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.text-ellipsis-3 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* ─── 评分星级 ───────────────────────────────────────────────────────────────── */
.score-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.score-high { background: #FDEDEC; color: #E74C3C; }
.score-medium-high { background: #FEF9E7; color: #F39C12; }
.score-medium { background: #EAFAF1; color: #27AE60; }
.score-low { background: #f0f0f0; color: #999; }

/* ─── 页面容器 ───────────────────────────────────────────────────────────────── */
.page-container {
  min-height: 100vh;
  background: var(--bg);
}

/* ─── flex 工具类 ────────────────────────────────────────────────────────────── */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }

/* ─── 间距工具类 ─────────────────────────────────────────────────────────────── */
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.px-30 { padding-left: 30rpx; padding-right: 30rpx; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }
